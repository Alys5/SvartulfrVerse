{
  "entities": {
    "LorebookFile": {
      "title": "Lorebook File",
      "description": "A file containing lorebook content (markdown or js)",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["md", "js"] },
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "content"]
    }
  },
  "firestore": {
    "/files/{fileId}": {
      "schema": { "$ref": "#/entities/LorebookFile" },
      "description": "Store all SvartulfrVerse canonical files."
    }
  }
}
