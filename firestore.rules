rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidLorebookFile(data) {
      return data.keys().hasAll(['title', 'type', 'content'])
        && data.title is string && data.title.size() <= 200
        && data.type is string && (data.type == 'md' || data.type == 'js')
        && data.content is string && data.content.size() <= 500000;
    }

    match /files/{fileId} {
      allow get, list: if true;
      allow create: if isSignedIn()
        && isValidId(fileId)
        && isValidLorebookFile(incoming())
        && incoming().keys().size() <= 4;
      allow update: if isSignedIn()
        && isValidId(fileId)
        && isValidLorebookFile(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'type', 'updatedAt']);
      allow delete: if isSignedIn()
        && isValidId(fileId);
    }
  }
}
